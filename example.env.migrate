# Service
SERVICE_NAME=auth-service-migrate

# Logs
LOG_LEVEL=info
LOG_OUTPUT=stderr
LOG_FORMAT=pretty

# Telemetry
TELEMETRY_ENABLED=false
TELEMETRY_SERVER=alloy:4317

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_SSL=disable
